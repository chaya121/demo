{
  "name": "temp-vite-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node backend/index.js",
    "build": "vite build && echo 'No build step'",
    "start": "cross-env NODE_ENV=production node backend/index.js node index.js",
    "lint": "eslint .",
    "preview": "npm run build && npm run start"

  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "jspdf": "^4.2.1",
    "mongoose": "^8.9.5",
    "pg": "^8.22.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "serverless-http": "^4.0.0",
    "sql.js": "^1.13.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  },
  "engines": {
    "node": "24.x"
  }
